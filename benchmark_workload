#!/bin/bash
# Benchmark workload - feste UB-Modell-Zuordnung
# Argumente: <results-file> <model> [--ub*-moe <wert>...] [-ctx <ctx>] [-ctv <ctv>] [-ctk <ctk>]
#
# Feste Zuordnung:
#   --ub0.5-moe <wert>  → -ub 512   → --n-cpu-moe <wert>
#   --ub1-moe <wert>    → -ub1 1024 → --n-cpu-moe <wert>
#   --ub2-moe <wert>    → -ub2 2048 → --n-cpu-moe <wert>
#   --ub3-moe <wert>    → -ub3 3072 → --n-cpu-moe <wert>
#   --ub4-moe <wert>    → -ub4 4096 → --n-cpu-moe <wert>

# Alle verfügbaren PP-Werte
ALL_PP_VALUES="96000,64000,32000,16000,8000,4000,2000,1000,500"

RESULTS_FILE="$1"
MODEL="$2"
shift 2

CTX="128000"
CTV="f16"
CTK="f16"

# --- Argumente parsen ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --ub0.5-moe) MOE_ARGS[512]="$2"; shift 2 ;;
        --ub1-moe)   MOE_ARGS[1024]="$2"; shift 2 ;;
        --ub2-moe)   MOE_ARGS[2048]="$2"; shift 2 ;;
        --ub3-moe)   MOE_ARGS[3072]="$2"; shift 2 ;;
        --ub4-moe)   MOE_ARGS[4096]="$2"; shift 2 ;;
        -ctx) CTX="$2"; shift 2 ;;
        -ctv) CTV="$2"; shift 2 ;;
        -ctk) CTK="$2"; shift 2 ;;
        *) shift ;;
    esac
done

# PP-Werte filtern: CTX ist aus Nutzersicht das Min-Kontext →
# wir filtern PP-Werte, die > CTX liegen (nur Werte ≤ CTX verwenden)
# z.B. CTX=8192 → PP = 8000,4000,2000,1000,500
PP_FILTERED=()
IFS=',' read -ra PP_ARR <<< "$ALL_PP_VALUES"
for val in "${PP_ARR[@]}"; do
    if [[ "$val" -le "$CTX" ]]; then
        PP_FILTERED+=("$val")
    fi
done
IFS=',' PP_VALUES="${PP_FILTERED[*]}"

# --- UB-Parameter und Modell-Zuordnung ---
declare -A UB_MAP=(
    [512]="ub"
    [1024]="ub1"
    [2048]="ub2"
    [3072]="ub3"
    [4096]="ub4"
)

declare -A MOE_MODEL=(
    [512]="ub512_moe"
    [1024]="ub1024_moe"
    [2048]="ub2048_moe"
    [3072]="ub3072_moe"
    [4096]="ub4096_moe"
)

# --- UB-Werte sortieren ---
UB_VALUES=()
for key in "${!UB_MAP[@]}"; do
    UB_VALUES+=("$key")
done
# Sortiert: 512, 1024, 2048, 3072, 4096
IFS=$'\n' UB_VALUES=($(sort -n <<<"${UB_VALUES[*]}")); unset IFS

# --- Prüfen ob mindestens ein Wert gefunden wurde ---
FOUND=0
for key in "${UB_VALUES[@]}"; do
    if [[ -n "${MOE_ARGS[$key]:-}" ]]; then
        FOUND=1
        break
    fi
done

if [[ "$FOUND" -eq 0 ]]; then
    echo "ERROR: Keine --ub*--moe Werte gefunden. Mindestens einer muss belegt sein."
    exit 1
fi

# --- Hyperfine-Kommandos nur für gefundene UB-Werte aufbauen ---
HYPERFINE_CMDS=()

for key in "${UB_VALUES[@]}"; do
    moe="${MOE_ARGS[$key]:-}"

    if [[ -z "$moe" ]]; then
        echo "  ⏭  -${UB_MAP[$key]} wird übersprungen (kein --${MOE_MODEL[$key]} gefunden)"
        continue
    fi

    HYPERFINE_CMDS+=(
        "llama-bench -hf $MODEL -dev CUDA0 --n-cpu-moe $moe -${UB_MAP[$key]} $key -b $key -ctk $CTK -ctv $CTV -p {PP} -n 1000 -fa 1 |tee -a $RESULTS_FILE-token-generation-results"
    )
done

echo "=============================================="
echo "  Minimaler Kontext     : $CTX"
echo "  Verwendete PP-Werte   : $PP_VALUES"
echo "  Benchmark für UB-Werte:"
echo "=============================================="
for key in "${UB_VALUES[@]}"; do
    moe="${MOE_ARGS[$key]:-}"
    if [[ -n "$moe" ]]; then
        echo "    -${UB_MAP[$key]}=$key → --n-cpu-moe=$moe  (${MOE_MODEL[$key]})"
    fi
done
echo "=============================================="
echo ""

# --- Hyperfine aufrufen mit dynamischen Kommandos ---
echo "Argument Results File: $RESULTS_FILE"
echo "Argument PP Values:    $PP_VALUES"
echo "Argument CMDS:         ${HYPERFINE_CMDS[@]}"
echo "Start..."
exec hyperfine --runs 2 --export-markdown "$RESULTS_FILE" --parameter-list PP "$PP_VALUES" "${HYPERFINE_CMDS[@]}" --show-output
